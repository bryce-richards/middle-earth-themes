  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#82868a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#4a5458"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#5a6064"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5a6458"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "support.constant"
      ],
      "settings": {
        "foreground": "#a5402a"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2a2c2e"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#a5402a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#50565a"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.self"
      ],
      "settings": {
        "foreground": "#5a6064",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#6a7074"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#4a5458"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#5a6064"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#a85420",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#a5402a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#5a6458",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#82868a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#4a5458"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#a5402a"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "keyword.control.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#a85420"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#5a6064",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#50565a",
    "property": "#50565a",
    "variable.constant": "#a5402a",
    "function": "#a85420",
    "method": "#a85420",
    "class": "#5a6064",
    "enumMember": "#a5402a",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}