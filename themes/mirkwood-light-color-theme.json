  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#7e846a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#4a6a44"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6a6a1e"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#5a5a86"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5a6a3a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "support.constant"
      ],
      "settings": {
        "foreground": "#7a4a7a"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "#6a6a1e"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2a3024"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#7a4a7a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#545a3e"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.self"
      ],
      "settings": {
        "foreground": "#5a5a86",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#6a7050"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#4a6a44"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6a6a1e"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#5a5a86"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#6a6a1e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#7a4a7a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#5a6a3a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#5a6a2a"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7e846a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#4a6a44"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list"
      ],
      "settings": {
        "foreground": "#6a6a1e"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#97402a"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "keyword.control.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#6a6a1e"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#5a5a86",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#545a3e",
    "property": "#545a3e",
    "variable.constant": "#7a4a7a",
    "function": "#6a6a1e",
    "method": "#6a6a1e",
    "class": "#5a5a86",
    "enumMember": "#7a4a7a",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}