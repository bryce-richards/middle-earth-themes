  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5a5d61",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#b54033"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#d9624a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#9aa6ac"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#8a8f8c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e08a3c"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "#e08a3c"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c4c2c0"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#e08a3c"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#aeb2b4"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.self"
      ],
      "settings": {
        "foreground": "#c0726a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#8a8d92"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b54033"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d9624a"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#9aa6ac"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d9624a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#e08a3c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#8a8f8c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#d9624a"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#5a5d61",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#9aa6ac"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list"
      ],
      "settings": {
        "foreground": "#d9624a"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e0452e"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "keyword.control.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#e08a3c"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#c0726a",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#aeb2b4",
    "property": "#aeb2b4",
    "variable.constant": "#e08a3c",
    "function": "#d9624a",
    "method": "#d9624a",
    "class": "#9aa6ac",
    "enumMember": "#e08a3c",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}