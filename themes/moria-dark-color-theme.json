  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5a606a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#7fa0b8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#b9c2cc"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#9fa6c4"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#8aa6a0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c9a94a"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "#c9a94a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c6cbd2"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#c9a94a"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#aab0ba"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.self"
      ],
      "settings": {
        "foreground": "#9fa6c4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#828892"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7fa0b8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b9c2cc"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#9fa6c4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#b9c2cc",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c9a94a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#8aa6a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#c9a94a"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#5a606a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7fa0b8"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list"
      ],
      "settings": {
        "foreground": "#b9c2cc"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c45a4a"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "keyword.control.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#c9a94a"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#9fa6c4",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#aab0ba",
    "property": "#aab0ba",
    "variable.constant": "#c9a94a",
    "function": "#b9c2cc",
    "method": "#b9c2cc",
    "class": "#9fa6c4",
    "enumMember": "#c9a94a",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}