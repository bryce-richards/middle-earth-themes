  "semanticTokenColors": {
    "parameter": "#57523c",
    "property": "#57523c",
    "variable.constant": "#a53318",
    "function": "#a55a1e",
    "method": "#a55a1e",
    "class": "#6a6448",
    "enumMember": "#a53318",
