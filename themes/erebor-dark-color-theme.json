      "settings": {
        "foreground": "#d65a44"
      }
    },
    {
      "scope": [
        "entity.name.label",
        "keyword.control.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#d65a44"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#cf9e5a",
        "fontStyle": "italic"
      }
    }
