  "semanticTokenColors": {
    "parameter": "#d2c294",
    "property": "#d2c294",
    "variable.constant": "#d65a44",
    "function": "#e8bf52",
    "method": "#e8bf52",
    "class": "#d4b87a",
    "enumMember": "#d65a44",
